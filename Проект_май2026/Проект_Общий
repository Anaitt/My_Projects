ek'])\n","\n","\n","    numerical_features = [\n","        'experience_years',\n","        'ai_tool_usage_hours_per_week',\n","        'tasks_automated_percent',\n","        'manual_work_hours_per_week',\n","        'learning_time_hours_per_week',\n","        'meeting_hours_per_week',\n","        'collaboration_hours_per_week',\n","        'error_rate_percent',\n","        'task_complexity_score',\n","        'focus_hours_per_day',\n","        'work_life_balance_score',\n","        'workload_hours_per_week',\n","        'ai_ratio'\n","    ]\n","\n","    categorical_ohe = ['job_role']\n","    categorical_ord = ['deadline_pressure_level']\n","\n","    deadline_order = [['Low', 'Medium', 'High']]\n","    if fit:\n","        ord_deadline = OrdinalEncoder(categories=deadline_order)\n","        df['deadline_pressure_encoded'] = ord_deadline.fit_transform(df[['deadline_pressure_level']])\n","    else:\n","        df['deadline_pressure_encoded'] = ord_deadline.transform(df[['deadline_pressure_level']])\n","\n","    if fit:\n","        ohe = OneHotEncoder(sparse_output=False, drop='first', handle_unknown='ignore')\n","        job_encoded = ohe.fit_transform(df[['job_role']])\n","    else:\n","        job_encoded = ohe.transform(df[['job_role']])\n","\n","    job_cols = [f'role_{cat}' for cat in ohe.categories_[0][1:]]\n","    job_df = pd.DataFrame(job_encoded, columns=job_cols, index=df.index)\n","\n","    X_num = df[numerical_features].values\n","\n","    if fit:\n","        scaler = StandardScaler()\n","        X_num_scaled = scaler.fit_transform(X_num)\n","    else:\n","        X_num_scaled = scaler.transform(X_num)\n","\n","    X_num_df = pd.DataFrame(X_num_scaled, columns=numerical_features, index=df.index)\n","\n","    X = pd.concat([X_num_df, job_df, df[['deadline_pressure_encoded']]], axis=1)\n","\n","    y_productivity = df['productivity_score']\n","\n","    burnout_order = [['Low', 'Medium', 'High']]\n","    if fit:\n","        ord_burnout = OrdinalEncoder(categori